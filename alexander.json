{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg-primary": "#0E1422",
    "bg-panel": "#161922",
    "coral": "#FF6B4A",
    "blue": "#00D4FF",
    "purple": "#D946FF",
    "gold": "#FFE600",
    "sky": "#00E5FF",
    "green": "#39FF14",
    "border-dark": "#1A2035",
    "border-active": "#1E2845",
    "text-dim": "#5A6070",
    "text-muted": "#7A8090",
    "text-faint": "#9AA0B0",
    "text-normal": "#D8DCE4",
    "text-bright": "#F0F2F5"
  },
  "theme": {
    "primary": { "dark": "blue", "light": "#00B8EE" },
    "secondary": { "dark": "purple", "light": "#A830E8" },
    "accent": { "dark": "purple", "light": "#A830E8" },
    "error": { "dark": "coral", "light": "#E85035" },
    "warning": { "dark": "gold", "light": "#E8D200" },
    "success": { "dark": "green", "light": "#00E878" },
    "info": { "dark": "blue", "light": "#00B8EE" },
    "text": { "dark": "text-bright", "light": "#1E2A3A" },
    "textMuted": { "dark": "text-muted", "light": "#4A5568" },
    "selectedListItemText": { "dark": "text-faint", "light": "#2D3A4A" },
    "background": { "dark": "bg-primary", "light": "#F0F4F8" },
    "backgroundPanel": { "dark": "bg-panel", "light": "#FFFFFF" },
    "backgroundElement": { "dark": "#121828", "light": "#E8ECF2" },
    "backgroundMenu": { "dark": "#121828", "light": "#FFFFFF" },
    "border": { "dark": "border-dark", "light": "#D0D8E0" },
    "borderActive": { "dark": "border-active", "light": "#00C8FF" },
    "borderSubtle": { "dark": "#141A2A", "light": "#E0E6EC" },
    "diffAdded": { "dark": "green", "light": "#00E878" },
    "diffRemoved": { "dark": "coral", "light": "#E85035" },
    "diffContext": { "dark": "text-dim", "light": "#8A95A5" },
    "diffHunkHeader": { "dark": "text-muted", "light": "#5A6575" },
    "diffHighlightAdded": { "dark": "green", "light": "#00E878" },
    "diffHighlightRemoved": { "dark": "coral", "light": "#E85035" },
    "diffAddedBg": { "dark": "#0A1E14", "light": "#E0FCE8" },
    "diffRemovedBg": { "dark": "#1E0A0E", "light": "#FCE0E4" },
    "diffContextBg": { "dark": "bg-primary", "light": "#F0F4F8" },
    "diffLineNumber": { "dark": "text-dim", "light": "#8A95A5" },
    "diffAddedLineNumberBg": { "dark": "#0A1E14", "light": "#E0FCE8" },
    "diffRemovedLineNumberBg": { "dark": "#1E0A0E", "light": "#FCE0E4" },
    "markdownText": { "dark": "text-normal", "light": "#1E2A3A" },
    "markdownHeading": { "dark": "coral", "light": "#E85035" },
    "markdownLink": { "dark": "sky", "light": "#00B8EE" },
    "markdownLinkText": { "dark": "purple", "light": "#A830E8" },
    "markdownCode": { "dark": "green", "light": "#00E878" },
    "markdownBlockQuote": { "dark": "text-dim", "light": "#8A95A5" },
    "markdownEmph": { "dark": "gold", "light": "#E8D200" },
    "markdownStrong": { "dark": "coral", "light": "#E85035" },
    "markdownHorizontalRule": { "dark": "border-dark", "light": "#D0D8E0" },
    "markdownListItem": { "dark": "blue", "light": "#00B8EE" },
    "markdownListEnumeration": { "dark": "purple", "light": "#A830E8" },
    "markdownImage": { "dark": "sky", "light": "#00B8EE" },
    "markdownImageText": { "dark": "purple", "light": "#A830E8" },
    "markdownCodeBlock": { "dark": "text-normal", "light": "#1E2A3A" },
    "syntaxComment": { "dark": "text-dim", "light": "#6A7585" },
    "syntaxKeyword": { "dark": "coral", "light": "#E85035" },
    "syntaxFunction": { "dark": "blue", "light": "#00B8EE" },
    "syntaxVariable": { "dark": "sky", "light": "#00B8EE" },
    "syntaxString": { "dark": "green", "light": "#00E878" },
    "syntaxNumber": { "dark": "gold", "light": "#E8D200" },
    "syntaxType": { "dark": "purple", "light": "#A830E8" },
    "syntaxOperator": { "dark": "coral", "light": "#E85035" },
    "syntaxPunctuation": { "dark": "text-faint", "light": "#5A6575" },
    "thinkingOpacity": 0.4
  }
}
